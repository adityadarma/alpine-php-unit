[supervisord]
nodaemon=true
logfile=/dev/null
logfile_maxbytes=0
pidfile=/run/supervisord.pid

[program:unit]
command=/usr/sbin/unitd --no-daemon
autostart=true
autorestart=true
startretries=0
priority=5

[program:laravel-queue]
command=/usr/bin/php /app/artisan queue:work
autostart=${WITH_QUEUE}
autorestart=true
startretries=0
priority=10

[program:laravel-schedule]
command=/usr/bin/php /app/artisan schedule:work
autostart=${WITH_SCHEDULE}
autorestart=true
startretries=0
priority=15