{
    "listeners": {
        "*:8000": {
            "pass": "routes"
        }
    },
    "routes": [
        {
            "match": {
                "uri": "/"
            },
            "action": {
                "pass": "applications/default"
            }
        },
        {
            "match": {
                "uri": "/index.php"
            },
            "action": {
                "pass": "applications/default"
            }
        },
        {
            "match": {
                "uri": "!/index.php"
            },
            "action": {
                "share": "/app/public$uri",
                "fallback": {
                    "pass": "applications/default"
                },
                "response_headers": {
                    "Cache-Control": "public, max-age=3600, must-revalidate, no-transform",
                    "Cross-Origin-Embedder-Policy": "require-corp",
                    "Cross-Origin-Resource-Policy": "same-origin",
                    "Referrer-Policy": "no-referrer",
                    "X-Content-Type-Options": "nosniff",
                    "X-Frame-Options": "deny",
                    "X-XSS-Protection": "1; mode=block"
                }
            }
        }
    ],
    "applications": {
        "default": {
            "type": "php",
            "root": "/app/public/",
            "script": "index.php",
            "processes": {
                "max": 50,
                "spare": 5,
                "idle_timeout": 10
            }
        }
    },
    "settings": {
        "http": {
            "body_read_timeout": 120,
            "header_read_timeout": 120,
            "idle_timeout": 10,
            "max_body_size": 52428800
        }
    },
    "access_log": {
        "path": "/dev/stdout",
        "format": "$remote_addr - - [$time_local] \"$request_line\" $status $body_bytes_sent \"$header_referer\" \"$header_user_agent\" \"$header_x_forwarded_for\""
    }
}
