{
    "listeners": {
        "*:8000": {
            "pass": "routes"
        }
    },
    "routes": [
        {
            "match": {
                "uri": "/*"
            },
            "action": {
                "share": "/app/public",
                "fallback": {
                    "pass": "applications/default"
                }
            }
        },
        {
            "match": {
                "uri": "/index.php"
            },
            "action": {
                "pass": "applications/default"
            }
        },
        {
            "match": {
                "uri": "/"
            },
            "action": {
                "share": "/app/public",
                "fallback": {
                    "pass": "applications/default"
                }
            }
        }
    ],
    "applications": {
        "default": {
            "type": "php",
            "root": "/app/public/",
            "script": "index.php",
            "processes": {
                "max": 50,
                "spare": 5,
                "idle_timeout": 10
            }
        }
    },
    "settings": {
        "http": {
            "body_read_timeout": 60,
            "header_read_timeout": 60,
            "idle_timeout": 60,
            "max_body_size": 10485760
        }
    }
}
